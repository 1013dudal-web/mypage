import React, { useState, useEffect } from 'react';
import { Sparkles, BrainCircuit, Heart, MessageCircle, RefreshCw, Send } from 'lucide-react';
import { initializeApp } from 'firebase/app';
import { getAuth, signInAnonymously, onAuthStateChanged } from 'firebase/auth';

const App = () => {
  const [input, setInput] = useState('');
  const [output, setOutput] = useState('');
  const [isLoading, setIsLoading] = useState(false);
  const [history, setHistory] = useState([]);
  const [user, setUser] = useState(null);

  // API configuration
  const apiKey = ""; // Runtime environment provides the key
  const modelName = "gemini-2.5-flash-preview-09-2025";

  // System prompt for the growth mindset coach
  const systemPrompt = `
    당신은 따뜻하고 공감 능력이 뛰어난 '수학 성장 마인드셋 코치'입니다.
    사용자가 수학에 대해 느끼는 부정적인 생각(고정 마인드셋)을 입력하면, 이를 긍정적이고 희망적인 '성장 마인드셋'으로 바꾸어 설명해 주세요.
    
    답변 원칙:
    1. 사용자의 감정을 먼저 공감해 줄 것.
    2. 수학은 타고나는 것이 아니라 '근육'처럼 단련할 수 있다는 점을 강조할 것.
    3. 구체적이고 실천 가능한 작은 격려를 포함할 것.
    4. 문체는 부드럽고 친절한 존댓말을 사용할 것.
    5. 답변의 길이는 3~4문장 정도로 적절히 유지할 것.
  `;

  // API call with exponential backoff
  const transformMindset = async () => {
    if (!input.trim()) return;

    setIsLoading(true);
    let retryCount = 0;
    const maxRetries = 5;

    const callApi = async () => {
      try {
        const response = await fetch(
          `https://generativelanguage.googleapis.com/v1beta/models/${modelName}:generateContent?key=${apiKey}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{ parts: [{ text: input }] }],
              systemInstruction: { parts: [{ text: systemPrompt }] }
            })
          }
        );

        if (!response.ok) throw new Error('API request failed');

        const data = await response.json();
        const resultText = data.candidates?.[0]?.content?.parts?.[0]?.text;
        
        if (resultText) {
          setOutput(resultText);
          setHistory(prev => [{ negative: input, positive: resultText }, ...prev.slice(0, 4)]);
          setInput('');
        }
      } catch (error) {
        if (retryCount < maxRetries) {
          retryCount++;
          const delay = Math.pow(2, retryCount) * 500; // 1s, 2s, 4s...
          await new Promise(resolve => setTimeout(resolve, delay));
          return callApi();
        } else {
          console.error("Failed after retries", error);
          setOutput("잠시 연결이 원활하지 않아요. 마음을 가다듬고 잠시 후 다시 시도해 볼까요?");
        }
      } finally {
        setIsLoading(false);
      }
    };

    await callApi();
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-rose-50 flex flex-col items-center p-4 md:p-8 font-sans text-slate-800">
      {/* Header */}
      <header className="max-w-2xl w-full text-center mb-12 animate-fade-in">
        <div className="inline-flex items-center justify-center p-3 bg-white rounded-2xl shadow-sm mb-4">
          <BrainCircuit className="w-8 h-8 text-indigo-500 mr-2" />
          <h1 className="text-2xl md:text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-rose-500">
            수학 마인드셋 도우미
          </h1>
        </div>
        <p className="text-slate-500 text-lg">
          여러분은 지금, 잘 해내고있어요.
        </p>
      </header>

      <main className="max-w-2xl w-full space-y-8">
        {/* Input Area */}
        <section className="bg-white/80 backdrop-blur-md p-6 rounded-3xl shadow-xl shadow-indigo-100/50 border border-white">
          <label className="block text-sm font-semibold text-slate-400 mb-3 ml-1">
            지금 마음속에 있는 수학에 대한 부담감을 적어주세요
          </label>
          <div className="relative">
            <textarea
              className="w-full h-32 p-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-indigo-300 focus:border-transparent outline-none transition-all resize-none text-lg"
              placeholder="예: 나는 수학 머리가 없나 봐요. 아무리 풀어도 모르겠어요."
              value={input}
              onChange={(e) => setInput(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                  e.preventDefault();
                  transformMindset();
                }
              }}
            />
            <button
              onClick={transformMindset}
              disabled={isLoading || !input.trim()}
              className={`absolute bottom-3 right-3 p-3 rounded-xl transition-all duration-300 ${
                isLoading || !input.trim() 
                  ? 'bg-slate-200 text-slate-400 cursor-not-allowed' 
                  : 'bg-indigo-500 text-white hover:bg-indigo-600 shadow-lg shadow-indigo-200 hover:scale-105 active:scale-95'
              }`}
            >
              {isLoading ? <RefreshCw className="w-5 h-5 animate-spin" /> : <Send className="w-5 h-5" />}
            </button>
          </div>
        </section>

        {/* Result Area */}
        {(output || isLoading) && (
          <section className="animate-in fade-in slide-in-from-bottom-4 duration-700">
            <div className="bg-gradient-to-r from-indigo-500 to-purple-500 p-px rounded-3xl overflow-hidden shadow-2xl">
              <div className="bg-white p-8 rounded-[23px]">
                <div className="flex items-center mb-4">
                  <div className="p-2 bg-rose-100 rounded-lg mr-3">
                    <Heart className="w-5 h-5 text-rose-500 fill-rose-500" />
                  </div>
                  <h2 className="text-xl font-bold text-slate-800">성장 마인드셋의 목소리</h2>
                </div>
                
                {isLoading ? (
                  <div className="space-y-3">
                    <div className="h-4 bg-slate-100 rounded-full w-3/4 animate-pulse"></div>
                    <div className="h-4 bg-slate-100 rounded-full w-full animate-pulse"></div>
                    <div className="h-4 bg-slate-100 rounded-full w-2/3 animate-pulse"></div>
                  </div>
                ) : (
                  <div className="text-slate-700 leading-relaxed text-lg whitespace-pre-wrap italic">
                    "{output}"
                  </div>
                )}
                
                {!isLoading && (
                  <div className="mt-6 flex justify-end">
                    <button 
                      onClick={() => { setOutput(''); setInput(''); }}
                      className="text-sm text-slate-400 hover:text-indigo-500 flex items-center transition-colors"
                    >
                      <RefreshCw className="w-4 h-4 mr-1" /> 다시 이야기하기
                    </button>
                  </div>
                )}
              </div>
            </div>
          </section>
        )}

        {/* History / Tips */}
        {history.length > 0 && (
          <section className="space-y-4">
            <h3 className="text-sm font-bold text-slate-400 uppercase tracking-wider ml-1">나의 마음 기록</h3>
            {history.map((item, index) => (
              <div key={index} className="bg-white/50 p-4 rounded-2xl border border-white/50 text-sm">
                <div className="flex items-start opacity-60 mb-2">
                  <MessageCircle className="w-4 h-4 mr-2 mt-0.5 text-slate-400" />
                  <p className="line-clamp-1">{item.negative}</p>
                </div>
                <div className="flex items-start text-indigo-600 font-medium">
                  <Sparkles className="w-4 h-4 mr-2 mt-0.5" />
                  <p className="line-clamp-2">{item.positive}</p>
                </div>
              </div>
            ))}
          </section>
        )}
        
        {/* Footer info */}
        <footer className="text-center py-10 opacity-40 text-xs">
          <p>© 수학 마인드셋 도우미 | 당신의 가능성은 무한합니다.</p>
        </footer>
      </main>

      <style dangerouslySetInnerHTML={{ __html: `
        @keyframes fade-in {
          from { opacity: 0; transform: translateY(-10px); }
          to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
          animation: fade-in 1s ease-out forwards;
        }
      `}} />
    </div>
  );
};

export default App;
